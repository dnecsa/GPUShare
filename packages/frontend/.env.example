# API Server URL
# IMPORTANT: This URL is used for API calls AND automatically added to Content Security Policy
# For local development, this defaults to http://localhost:8000
# For production, set this to your actual API server URL (e.g., https://gpu.yourdomain.com)
# The origin (protocol + domain + port) will be extracted and allowed in CSP
VITE_API_URL=http://localhost:8000

# Stripe Publishable Key
# Get this from your Stripe Dashboard (https://dashboard.stripe.com/apikeys)
# Use test key (pk_test_...) for development, live key (pk_live_...) for production
# Example: VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51...
VITE_STRIPE_PUBLISHABLE_KEY=

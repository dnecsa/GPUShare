# =============================================================================
# GPU Node — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Or just run ./setup.sh which will generate it for you.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/gpunode
JWT_SECRET=change-me-to-a-random-64-char-string
ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Services and compute
# -----------------------------------------------------------------------------
SERVICES_ENABLED=inference,render     # comma-separated: inference, render
MODELS=qwen2.5:14b                   # Ollama models to advertise (auto-detected)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_KEEP_ALIVE=15m                # unload model from VRAM after idle
BLENDER_PATH=/usr/bin/blender
BLENDER_MAX_CONCURRENT_JOBS=1

# -----------------------------------------------------------------------------
# Billing (optional — all $ amounts hidden when Stripe not configured)
# -----------------------------------------------------------------------------
ELECTRICITY_RATE_KWH=0.346           # your rate in local currency per kWh
CURRENCY=NZD                         # ISO 4217 currency code
GPU_INFERENCE_WATTS=150              # GPU draw during inference
GPU_RENDER_WATTS=300                 # GPU draw during Cycles render
SYSTEM_WATTS=80                      # CPU + RAM + drives
BILLING_ENABLED=false                # set true + configure Stripe to enable
SOFT_LIMIT_WARN=-5.00
HARD_LIMIT_DEFAULT=-20.00
INVOICE_DAY=1

# -----------------------------------------------------------------------------
# Stripe (optional — enables billing, top-ups, invoices)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=                   # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=               # whsec_...

# -----------------------------------------------------------------------------
# OpenRouter (optional — adds cloud AI models like GPT-4o, Claude)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=                  # from openrouter.ai/keys
OPENROUTER_MODELS=                   # comma-separated, e.g. openai/gpt-4o,anthropic/claude-sonnet-4

# -----------------------------------------------------------------------------
# Cloudflare R2 (optional — required for 3D rendering file storage)
# -----------------------------------------------------------------------------
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=gpu-node-files

# -----------------------------------------------------------------------------
# Resend (optional — email notifications)
# -----------------------------------------------------------------------------
RESEND_API_KEY=                      # from resend.com/api-keys

# -----------------------------------------------------------------------------
# Tapo smart plug (optional — real-time energy monitoring)
# -----------------------------------------------------------------------------
TAPO_EMAIL=                          # your TP-Link/Tapo account email
TAPO_PASSWORD=                       # your TP-Link/Tapo account password
TAPO_DEVICE_IP=                      # local IP of your Tapo P110 plug

# -----------------------------------------------------------------------------
# Signup and access
# -----------------------------------------------------------------------------
INVITE_ONLY=true
REQUIRE_APPROVAL=true
NODE_NAME=My GPU Node
INITIAL_ADMIN_BOOTSTRAP_TOKEN=change-me-before-first-signup

# -----------------------------------------------------------------------------
# API Key generation
# -----------------------------------------------------------------------------
# API_KEY_PREFIX=gpus_sk_

# Optional: default credit amount for new users created via invite (in NZD)
# DEFAULT_CREDITS_NZD=1.00

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (optional — for permanent URLs)
# -----------------------------------------------------------------------------
TUNNEL_TOKEN=

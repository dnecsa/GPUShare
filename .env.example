# =============================================================================
# GPU Node — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/gpunode
JWT_SECRET=change-me-to-a-random-64-char-string
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=gpu-node-files
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# Services and compute
# -----------------------------------------------------------------------------
SERVICES_ENABLED=inference,render
MODELS=qwen2.5:14b,llama3.1:8b
OLLAMA_HOST=http://localhost:11434
OLLAMA_KEEP_ALIVE=15m
BLENDER_PATH=/usr/bin/blender
BLENDER_MAX_CONCURRENT_JOBS=1

# -----------------------------------------------------------------------------
# Billing
# -----------------------------------------------------------------------------
ELECTRICITY_RATE_KWH=0.346
CURRENCY=NZD
GPU_INFERENCE_WATTS=150
GPU_RENDER_WATTS=300
SYSTEM_WATTS=80
BILLING_ENABLED=true
SOFT_LIMIT_WARN=-5.00
HARD_LIMIT_DEFAULT=-20.00
INVOICE_DAY=1

# -----------------------------------------------------------------------------
# Signup and access
# -----------------------------------------------------------------------------
INVITE_ONLY=true
REQUIRE_APPROVAL=true
NODE_NAME=My GPU Node
ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Cloudflare Tunnel
# -----------------------------------------------------------------------------
TUNNEL_TOKEN=
